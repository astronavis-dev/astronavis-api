```gitignore
# =========================================================
# Astronavis Global .gitignore
# =========================================================

# ---------------------------------------------------------
# Rust
# ---------------------------------------------------------
target/
debug/
release/

# Backup / temp
*.bak
*.tmp
*.temp
*.old

# Rust incremental compilation
.incremental/

# Keep Cargo.lock only for binaries/applications if desired
#! Cargo.lock

# Rustfmt backups
**/*.rs.bk

# ---------------------------------------------------------
# SQLite / Databases
# ---------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db3
*.db-journal
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Temporary DBs
tmp.db
temp.db

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
*.log
logs/
log/

# ---------------------------------------------------------
# Coverage / profiling
# ---------------------------------------------------------
coverage/
*.profraw
*.profdata

# tarpaulin
tarpaulin-report.html

# ---------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------
.env
.env.*
!.env.example

*.secret
*.key
*.pem
*.crt
*.pfx
*.p12

# ---------------------------------------------------------
# IDEs / Editors
# ---------------------------------------------------------

# JetBrains
.idea/
*.iml

# VSCode
.vscode/

# Fleet
.fleet/

# Vim
*.swp
*.swo

# ---------------------------------------------------------
# OS files
# ---------------------------------------------------------

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# Linux
*~

# ---------------------------------------------------------
# Node / frontend
# ---------------------------------------------------------
node_modules/
dist/
build/

# npm/yarn/pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------
# Python
# ---------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ---------------------------------------------------------
# Generated documentation
# ---------------------------------------------------------
site/
public/

# mdBook
book/

# ---------------------------------------------------------
# Docker
# ---------------------------------------------------------
.docker/

# ---------------------------------------------------------
# Terraform
# ---------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*

# ---------------------------------------------------------
# Kubernetes
# ---------------------------------------------------------
kubeconfig

# ---------------------------------------------------------
# Temporary exports
# ---------------------------------------------------------
exports/
generated/
tmp/
temp/

# ---------------------------------------------------------
# Binary artifacts
# ---------------------------------------------------------
*.exe
*.dll
*.so
*.dylib

# ---------------------------------------------------------
# Archives
# ---------------------------------------------------------
*.zip
*.7z
*.tar
*.tar.gz
*.rar

# ---------------------------------------------------------
# Misc
# ---------------------------------------------------------
.cache/
.cache-loader/

# Generated screenshots/images
screenshots/
captures/

# Local testing
test-output/
bench-output/
```
